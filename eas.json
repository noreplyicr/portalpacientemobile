{
	"cli": {
		"version": ">= 18.3.0",
		"appVersionSource": "local"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"android": {
				"credentialsSource": "local"
			},
			"env": {
				"NPM_CONFIG_LEGACY_PEER_DEPS": "1"
			}
		},
		"preview": {
			"distribution": "internal",
			"android": {
				"buildType": "apk",
				"credentialsSource": "local"
			},
			"env": {
				"NPM_CONFIG_LEGACY_PEER_DEPS": "1"
			}
		},
		"production": {
			"autoIncrement": false,
			"android": {
				"buildType": "app-bundle",
				"credentialsSource": "local"
			},
			"env": {
				"NPM_CONFIG_LEGACY_PEER_DEPS": "1"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
